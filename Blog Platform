<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>BlogSpace</title>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
body{font-family:'Segoe UI',system-ui,sans-serif;background:#f0f2f5;color:#222;line-height:1.6}
a{text-decoration:none;color:inherit}
.navbar{display:flex;justify-content:space-between;align-items:center;background:#1a1a2e;padding:.8rem 2rem;position:sticky;top:0;z-index:100}
.brand{color:#e94560;font-size:1.4rem;font-weight:700;cursor:pointer}
.nav-links{display:flex;align-items:center;gap:1rem}
.nav-links span{color:#ccc;font-size:.9rem}
.nav-links a,.nav-links button{color:#ccc;background:none;border:none;cursor:pointer;font-size:.95rem}
.nav-links a:hover,.nav-links button:hover{color:#fff}
.btn{background:#e94560;color:#fff;border:none;padding:.5rem 1.2rem;border-radius:6px;cursor:pointer;font-size:.95rem;transition:background .2s;display:inline-block}
.btn:hover{background:#c73652}
.btn-sm{padding:.35rem .9rem;font-size:.85rem}
.btn-outline{background:transparent;border:1px solid #e94560;color:#e94560}
.btn-outline:hover{background:#e94560;color:#fff}
.btn-danger{background:#dc3545}.btn-danger:hover{background:#b02a37}
.btn-link{background:none;border:none;cursor:pointer;font-size:.85rem;color:#dc3545;padding:0}
.container{max-width:820px;margin:2rem auto;padding:0 1rem}
.card{background:#fff;border-radius:10px;padding:1.5rem;margin-bottom:1.2rem;box-shadow:0 2px 8px rgba(0,0,0,.07)}
.card h2{font-size:1.25rem;margin-bottom:.3rem;color:#1a1a2e;cursor:pointer}
.card h2:hover{color:#e94560}
.meta{color:#888;font-size:.82rem;margin-bottom:.5rem}
.excerpt{color:#444;margin-bottom:.8rem}
.read-more{color:#e94560;font-size:.9rem;cursor:pointer}
.tags{display:flex;flex-wrap:wrap;gap:.4rem;margin-bottom:.7rem}
.tag{background:#f0f0f0;color:#555;padding:.2rem .6rem;border-radius:20px;font-size:.75rem}
.post-content{margin:1.5rem 0;white-space:pre-wrap;line-height:1.8;color:#333}
.post-actions{display:flex;gap:.8rem;margin-top:1rem}
.auth-box{max-width:420px;margin:3rem auto;background:#fff;padding:2rem;border-radius:10px;box-shadow:0 2px 12px rgba(0,0,0,.1)}
.auth-box h2{margin-bottom:1.2rem}
.auth-box p{margin-top:1rem;font-size:.9rem;color:#555}
.auth-box p a{color:#e94560;cursor:pointer}
input,textarea{width:100%;padding:.6rem .9rem;border:1px solid #ddd;border-radius:6px;font-size:.95rem;margin-bottom:1rem;font-family:inherit;transition:border-color .2s}
input:focus,textarea:focus{outline:none;border-color:#e94560}
.post-form{background:#fff;border-radius:10px;padding:2rem;box-shadow:0 2px 8px rgba(0,0,0,.07)}
.post-form h2{margin-bottom:1.2rem}
.error{color:#dc3545;margin-bottom:.8rem;font-size:.9rem;padding:.5rem;background:#fff0f0;border-radius:4px}
.success{color:#198754;margin-bottom:.8rem;font-size:.9rem;padding:.5rem;background:#f0fff4;border-radius:4px}
.center{text-align:center;margin-top:3rem;color:#888}
.comments{margin-top:2rem;border-top:1px solid #eee;padding-top:1.5rem}
.comments h3{margin-bottom:1rem}
.comment{padding:.8rem 0;border-bottom:1px solid #f0f0f0}
.comment-meta{color:#888;font-size:.8rem;margin-bottom:.3rem}
.comment-form{margin-top:1.2rem}
.login-prompt{margin-top:1rem;color:#666;font-size:.9rem}
.login-prompt a{color:#e94560;cursor:pointer}
.page-title{font-size:1.8rem;margin-bottom:1.5rem;color:#1a1a2e}
.back-btn{color:#e94560;cursor:pointer;font-size:.9rem;margin-bottom:1rem;display:inline-block}
.back-btn:hover{text-decoration:underline}
.empty{text-align:center;padding:3rem;color:#888}
.empty p{font-size:1.1rem;margin-bottom:1rem}
</style>
</head>
<body>

<div id="app"></div>

<script>
// ─── In-memory "database" ───────────────────────────────────────────────────
const DB = {
  users: JSON.parse(localStorage.getItem('bp_users') || '[]'),
  posts: JSON.parse(localStorage.getItem('bp_posts') || '[]'),
  comments: JSON.parse(localStorage.getItem('bp_comments') || '[]'),
  save() {
    localStorage.setItem('bp_users', JSON.stringify(this.users));
    localStorage.setItem('bp_posts', JSON.stringify(this.posts));
    localStorage.setItem('bp_comments', JSON.stringify(this.comments));
  }
};

// ─── Auth state ─────────────────────────────────────────────────────────────
let currentUser = JSON.parse(localStorage.getItem('bp_session') || 'null');

function setSession(user) {
  currentUser = user;
  if (user) localStorage.setItem('bp_session', JSON.stringify(user));
  else localStorage.removeItem('bp_session');
}

// ─── Router ─────────────────────────────────────────────────────────────────
let currentPage = 'home';
let routeParam = null;

function navigate(page, param = null) {
  currentPage = page;
  routeParam = param;
  render();
  window.scrollTo(0, 0);
}

// ─── Helpers ────────────────────────────────────────────────────────────────
function uid() { return Date.now().toString(36) + Math.random().toString(36).slice(2); }
function fmt(ts) { return new Date(ts).toLocaleDateString('en-US', { year:'numeric', month:'short', day:'numeric' }); }
function esc(str) {
  const d = document.createElement('div');
  d.textContent = str;
  return d.innerHTML;
}

// ─── Render engine ──────────────────────────────────────────────────────────
function render() {
  const app = document.getElementById('app');
  app.innerHTML = navbar() + '<div class="container">' + renderPage() + '</div>';
  attachEvents();
}

function navbar() {
  return `<nav class="navbar">
    <span class="brand" onclick="navigate('home')">BlogSpace</span>
    <div class="nav-links">
      ${currentUser
        ? `<span>Hi, ${esc(currentUser.username)}</span>
           <button class="btn btn-sm" onclick="navigate('create')">+ New Post</button>
           <button class="btn-outline btn btn-sm" onclick="logout()">Logout</button>`
        : `<a onclick="navigate('login')">Login</a>
           <button class="btn btn-sm" onclick="navigate('register')">Register</button>`
      }
    </div>
  </nav>`;
}

function renderPage() {
  switch (currentPage) {
    case 'home':     return pageHome();
    case 'login':    return pageLogin();
    case 'register': return pageRegister();
    case 'post':     return pagePost(routeParam);
    case 'create':   return pageCreate();
    case 'edit':     return pageEdit(routeParam);
    default:         return pageHome();
  }
}
</script>

<script>
// ─── Pages ──────────────────────────────────────────────────────────────────

function pageHome() {
  const posts = [...DB.posts].sort((a, b) => b.createdAt - a.createdAt);
  if (posts.length === 0) return `
    <h1 class="page-title">Latest Posts</h1>
    <div class="empty">
      <p>No posts yet. Be the first to write one!</p>
      ${currentUser ? `<button class="btn" onclick="navigate('create')">Write a Post</button>` : `<button class="btn" onclick="navigate('register')">Get Started</button>`}
    </div>`;

  return `<h1 class="page-title">Latest Posts</h1>` +
    posts.map(p => {
      const author = DB.users.find(u => u.id === p.authorId);
      const commentCount = DB.comments.filter(c => c.postId === p.id).length;
      const tagsHtml = p.tags?.length ? `<div class="tags">${p.tags.map(t => `<span class="tag">${esc(t)}</span>`).join('')}</div>` : '';
      return `<div class="card">
        <h2 onclick="navigate('post','${p.id}')">${esc(p.title)}</h2>
        <p class="meta">By ${esc(author?.username || 'Unknown')} &middot; ${fmt(p.createdAt)} &middot; ${commentCount} comment${commentCount !== 1 ? 's' : ''}</p>
        ${tagsHtml}
        <p class="excerpt">${esc(p.content.slice(0, 160))}${p.content.length > 160 ? '...' : ''}</p>
        <span class="read-more" onclick="navigate('post','${p.id}')">Read more &rarr;</span>
      </div>`;
    }).join('');
}

function pageLogin() {
  return `<div class="auth-box">
    <h2>Login</h2>
    <div id="msg"></div>
    <form id="loginForm">
      <input type="email" id="lemail" placeholder="Email" required />
      <input type="password" id="lpass" placeholder="Password" required />
      <button type="submit" class="btn" style="width:100%">Login</button>
    </form>
    <p>Don't have an account? <a onclick="navigate('register')">Register</a></p>
  </div>`;
}

function pageRegister() {
  return `<div class="auth-box">
    <h2>Create Account</h2>
    <div id="msg"></div>
    <form id="registerForm">
      <input type="text" id="ruser" placeholder="Username" required />
      <input type="email" id="remail" placeholder="Email" required />
      <input type="password" id="rpass" placeholder="Password (min 6 chars)" minlength="6" required />
      <button type="submit" class="btn" style="width:100%">Register</button>
    </form>
    <p>Already have an account? <a onclick="navigate('login')">Login</a></p>
  </div>`;
}

function pagePost(id) {
  const post = DB.posts.find(p => p.id === id);
  if (!post) return `<p class="center">Post not found. <span class="read-more" onclick="navigate('home')">Go home</span></p>`;
  const author = DB.users.find(u => u.id === post.authorId);
  const isOwner = currentUser?.id === post.authorId;
  const tagsHtml = post.tags?.length ? `<div class="tags">${post.tags.map(t => `<span class="tag">${esc(t)}</span>`).join('')}</div>` : '';
  const comments = DB.comments.filter(c => c.postId === id).sort((a, b) => a.createdAt - b.createdAt);

  const commentsHtml = comments.map(c => {
    const ca = DB.users.find(u => u.id === c.authorId);
    const canDel = currentUser?.id === c.authorId;
    return `<div class="comment">
      <p class="comment-meta">${esc(ca?.username || 'Unknown')} &middot; ${fmt(c.createdAt)}</p>
      <p>${esc(c.content)}</p>
      ${canDel ? `<button class="btn-link" onclick="deleteComment('${c.id}','${id}')">Delete</button>` : ''}
    </div>`;
  }).join('');

  const commentForm = currentUser
    ? `<form id="commentForm" class="comment-form">
        <div id="cmsg"></div>
        <textarea id="ctext" placeholder="Write a comment..." rows="3" required></textarea>
        <button type="submit" class="btn btn-sm">Post Comment</button>
       </form>`
    : `<p class="login-prompt"><a onclick="navigate('login')">Login</a> to leave a comment.</p>`;

  return `
    <span class="back-btn" onclick="navigate('home')">&larr; Back to posts</span>
    <div class="card">
      <h2 style="font-size:1.8rem;margin-bottom:.4rem">${esc(post.title)}</h2>
      <p class="meta">By ${esc(author?.username || 'Unknown')} &middot; ${fmt(post.createdAt)}</p>
      ${tagsHtml}
      <div class="post-content">${esc(post.content)}</div>
      ${isOwner ? `<div class="post-actions">
        <button class="btn btn-sm" onclick="navigate('edit','${post.id}')">Edit</button>
        <button class="btn btn-danger btn-sm" onclick="deletePost('${post.id}')">Delete</button>
      </div>` : ''}
    </div>
    <div class="card">
      <div class="comments">
        <h3>Comments (${comments.length})</h3>
        ${commentsHtml || '<p style="color:#aaa;font-size:.9rem">No comments yet.</p>'}
        ${commentForm}
      </div>
    </div>`;
}

function pageCreate() {
  if (!currentUser) { navigate('login'); return ''; }
  return `<div class="post-form">
    <h2>New Post</h2>
    <div id="msg"></div>
    <form id="createForm">
      <input type="text" id="ptitle" placeholder="Title" required />
      <textarea id="pcontent" placeholder="Write your post..." rows="10" required></textarea>
      <input type="text" id="ptags" placeholder="Tags (comma separated, optional)" />
      <button type="submit" class="btn">Publish</button>
    </form>
  </div>`;
}

function pageEdit(id) {
  if (!currentUser) { navigate('login'); return ''; }
  const post = DB.posts.find(p => p.id === id);
  if (!post || post.authorId !== currentUser.id) { navigate('home'); return ''; }
  return `<div class="post-form">
    <h2>Edit Post</h2>
    <div id="msg"></div>
    <form id="editForm">
      <input type="text" id="etitle" value="${esc(post.title)}" required />
      <textarea id="econtent" rows="10" required>${esc(post.content)}</textarea>
      <input type="text" id="etags" value="${esc(post.tags?.join(', ') || '')}" placeholder="Tags (comma separated)" />
      <button type="submit" class="btn">Update</button>
    </form>
  </div>`;
}
</script>

<script>
// ─── Event attachment ────────────────────────────────────────────────────────

function attachEvents() {
  const loginForm = document.getElementById('loginForm');
  if (loginForm) loginForm.addEventListener('submit', handleLogin);

  const registerForm = document.getElementById('registerForm');
  if (registerForm) registerForm.addEventListener('submit', handleRegister);

  const createForm = document.getElementById('createForm');
  if (createForm) createForm.addEventListener('submit', handleCreate);

  const editForm = document.getElementById('editForm');
  if (editForm) editForm.addEventListener('submit', handleEdit);

  const commentForm = document.getElementById('commentForm');
  if (commentForm) commentForm.addEventListener('submit', handleComment);
}

function showMsg(id, text, type = 'error') {
  const el = document.getElementById(id);
  if (el) el.innerHTML = `<p class="${type}">${esc(text)}</p>`;
}

// ─── Auth handlers ───────────────────────────────────────────────────────────

function handleLogin(e) {
  e.preventDefault();
  const email = document.getElementById('lemail').value.trim();
  const pass  = document.getElementById('lpass').value;
  const user  = DB.users.find(u => u.email === email && u.password === pass);
  if (!user) return showMsg('msg', 'Invalid email or password');
  setSession({ id: user.id, username: user.username });
  navigate('home');
}

function handleRegister(e) {
  e.preventDefault();
  const username = document.getElementById('ruser').value.trim();
  const email    = document.getElementById('remail').value.trim().toLowerCase();
  const password = document.getElementById('rpass').value;

  if (DB.users.find(u => u.email === email))    return showMsg('msg', 'Email already registered');
  if (DB.users.find(u => u.username === username)) return showMsg('msg', 'Username taken');

  const user = { id: uid(), username, email, password, createdAt: Date.now() };
  DB.users.push(user);
  DB.save();
  setSession({ id: user.id, username: user.username });
  navigate('home');
}

function logout() {
  setSession(null);
  navigate('home');
}

// ─── Post handlers ───────────────────────────────────────────────────────────

function handleCreate(e) {
  e.preventDefault();
  const title   = document.getElementById('ptitle').value.trim();
  const content = document.getElementById('pcontent').value.trim();
  const tags    = document.getElementById('ptags').value.split(',').map(t => t.trim()).filter(Boolean);
  if (!title || !content) return showMsg('msg', 'Title and content are required');

  const post = { id: uid(), title, content, tags, authorId: currentUser.id, createdAt: Date.now() };
  DB.posts.push(post);
  DB.save();
  navigate('post', post.id);
}

function handleEdit(e) {
  e.preventDefault();
  const post = DB.posts.find(p => p.id === routeParam);
  if (!post) return;
  post.title   = document.getElementById('etitle').value.trim();
  post.content = document.getElementById('econtent').value.trim();
  post.tags    = document.getElementById('etags').value.split(',').map(t => t.trim()).filter(Boolean);
  post.updatedAt = Date.now();
  DB.save();
  navigate('post', post.id);
}

function deletePost(id) {
  if (!confirm('Delete this post?')) return;
  DB.posts = DB.posts.filter(p => p.id !== id);
  DB.comments = DB.comments.filter(c => c.postId !== id);
  DB.save();
  navigate('home');
}

// ─── Comment handlers ────────────────────────────────────────────────────────

function handleComment(e) {
  e.preventDefault();
  const content = document.getElementById('ctext').value.trim();
  if (!content) return showMsg('cmsg', 'Comment cannot be empty');
  const comment = { id: uid(), content, postId: routeParam, authorId: currentUser.id, createdAt: Date.now() };
  DB.comments.push(comment);
  DB.save();
  navigate('post', routeParam);
}

function deleteComment(commentId, postId) {
  DB.comments = DB.comments.filter(c => c.id !== commentId);
  DB.save();
  navigate('post', postId);
}

// ─── Boot ────────────────────────────────────────────────────────────────────
render();
</script>
</body>
</html>
